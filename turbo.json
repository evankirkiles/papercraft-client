{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "lint": {},
    "typecheck": {},
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build:dev": {
      "outputs": ["dist/**"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "preview": {
      "dependsOn": ["build"],
      "persistent": true,
      "cache": false
    }
  }
}
